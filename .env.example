# ─── Database ───
# PostgreSQL connection string
# For Docker Compose local: postgresql://pos_user:pos_password@db:5432/pos_db
# For Prisma Accelerate: see https://www.prisma.io/data-platform/accelerate
DATABASE_URL=postgresql://pos_user:pos_password@localhost:5432/pos_db

# ─── Authentication ───
# IMPORTANT: Change this to a strong random string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_strong_random_string

# ─── Server ───
PORT=3000
NODE_ENV=development

# ─── CORS ───
# Comma-separated allowed origins. Use * for development only.
# Example: http://localhost:5173,https://myapp.com
CORS_ORIGIN=*

# ─── Docker Compose (optional, for local DB) ───
DB_USER=pos_user
DB_PASSWORD=pos_password
DB_NAME=pos_db
